<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sala Expositiva 3D</title>
<link href="https://fonts.googleapis.com/css2?family=Fira+Code&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
<style>
  body {
    margin: 0;
    font-family: 'Roboto', sans-serif;
    background-color: #061D39;
    color: #EBEBEB;
  }

  .container {
    display: flex;
    height: 100vh;
  }

  .sidebar {
    width: 300px;
    background-color: #EBEBEB;
    color: #061D39;
    display: flex;
    flex-direction: column;
    padding: 20px;
    box-sizing: border-box;
    font-family: 'Roboto', sans-serif;
  }

  .sidebar h2 {
    margin-top: 0;
    font-weight: 700;
  }

  .code-input {
    font-family: 'Fira Code', monospace;
    font-size: 16px;
    padding: 10px;
    margin-bottom: 15px;
    border: 1px solid #A2A2A2;
    border-radius: 6px;
    outline: none;
    background-color: #EBEBEB;
    color: #061D39;
    width: 100%;
    box-sizing: border-box;
  }

  .button {
    padding: 10px 15px;
    background-color: #8F95A5;
    color: #EBEBEB;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    margin-bottom: 15px;
    transition: background 0.2s;
    font-weight: 500;
  }

  .button:hover {
    background-color: #A2A2A2;
  }

  .object-info {
    flex: 1;
    overflow-y: auto;
    margin-top: 10px;
    font-size: 14px;
    line-height: 1.5;
    color: #061D39;
  }

  .main {
    flex: 1;
    background-color: #061D39;
    position: relative;
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <h2>Galería 3D</h2>
      <input class="code-input" placeholder="Introduce código de obra..." />
      <button class="button">Buscar / Iluminar</button>
      <div class="object-info">
        <p>Información de la obra aparecerá aquí...</p>
      </div>
    </div>
    <div class="main">
      <canvas id="threeCanvas"></canvas>
    </div>
  </div>
</body>
</html>
